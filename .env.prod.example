# Production .env.prod (copy to .env.prod and edit).
# Used by docker-compose.prod.yml via ${VAR} interpolation.

POSTGRES_USER=oj
POSTGRES_PASSWORD=change-this-strong-postgres-password
POSTGRES_DB=codefyui_oj

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-this-min-48-chars-random-secret

# JSON list (escaped). Front-end URL the API will accept.
CORS_ORIGINS=["https://oj.example.com"]
