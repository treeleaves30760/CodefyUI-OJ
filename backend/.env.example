# Copy to .env and adjust
DEBUG=true

# DB: sqlite for dev, postgres for prod
DATABASE_URL=sqlite+aiosqlite:///./oj.db
# DATABASE_URL=postgresql+asyncpg://oj:oj@localhost:5432/oj

REDIS_URL=redis://localhost:6379/0

# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=dev-secret-change-me-in-production

# Phase 4+: switch to Docker sandbox
JUDGE_USE_DOCKER=false
CDUI_REPO_PATH=../CodefyUI

CORS_ORIGINS=["http://localhost:5173"]

# Deployment mode: "competition" (default, full auth + contests) or "practice"
# (no-login single-user local mode for solo students).
APP_MODE=competition

# Optional: auto-create the first admin on boot when APP_MODE=competition and
# no admin exists yet. Useful for k8s / containerized deployments where you
# can't reach the /setup UI. Idempotent — subsequent boots skip.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me
# BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
